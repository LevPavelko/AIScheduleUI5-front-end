<mvc:View xmlns:mvc="sap.ui.core.mvc"
		  xmlns:m="sap.m"
		  xmlns:unified="sap.ui.unified"
		  controllerName="sap.ui.schedule.controller.App">

	<m:App id="app">
		<m:SinglePlanningCalendar
			id="planningCalendar"
			startDate="{/startDate}"
			appointments="{/appointments}"
			selectedView="Day"
			fullDay="false"
			appointmentSelect=".onAppointmentSelect">

			<m:views>
				<m:SinglePlanningCalendarDayView key="Day" title="Stunden"/>
				<m:SinglePlanningCalendarWorkWeekView key="Week" title="1 Woche"/>
			</m:views>

			<m:appointments>
				<unified:CalendarAppointment
					title="{title}"
					text="{timeRange}"
					startDate="{startDate}"
					endDate="{endDate}"
					type="{type}"/>
			</m:appointments>

		</m:SinglePlanningCalendar>
	</m:App>
</mvc:View>


