<mvc:View
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:form="sap.ui.layout.form"
	controllerName="sap.ui.schedule.controller.SignUp"
	displayBlock="true">

	<App id="signUpApp">
		<pages>
			<Page showHeader="false" backgroundDesign="Solid">
				<content>
					<VBox
						height="100%"
						justifyContent="Center"
						alignItems="Center">
						<Panel
							width="22rem"
							headerText="Sign Up"
							class="sapUiMediumMargin">
							<form:SimpleForm
								editable="true"
								layout="ResponsiveGridLayout"
								labelSpanL="3" labelSpanM="3"
								emptySpanL="0" emptySpanM="0"
								columnsL="1" columnsM="1">
								<form:content>
									<Label text="Name"/>
									<Input id="Name"
										   placeholder="Enter name"/>

									<Label text="Email"/>
									<Input id="Email"
										   placeholder="Enter email"/>

									<Label text="Password"/>
									<Input id="Password"
										   type="Password"
										   placeholder="Enter password"/>

									<Label text="Repeat password"/>
									<Input id="RepeatPassword"
										   type="Password"
										   placeholder="Enter password again"/>
									<Label id="warning"  text=""  />


									<Button text="Sign Up"
											type="Emphasized"
											width="100%"
											press="onBtnClick"/>

								</form:content>
							</form:SimpleForm>

						</Panel>
					</VBox>
				</content>
			</Page>

		</pages>

	</App>
</mvc:View>